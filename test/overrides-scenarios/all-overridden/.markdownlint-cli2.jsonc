{
  "config": {
    "no-trailing-spaces": false
  },
  "overrides": [
    {
      "filter": [ "*il*.md" ],
      "config": {
        "single-trailing-newline": false
      },
      "combine": "merge"
    },
    {
      "filter": [ "*op*.md" ],
      "config": {
        "no-multiple-space-atx": false
      },
      "combine": "merge"
    }
  ]
}
